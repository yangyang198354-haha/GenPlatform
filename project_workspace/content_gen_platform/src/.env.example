# ── Django ────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_SETTINGS_MODULE=config.settings.production

# ── Encryption (32-byte AES key, base64-encoded) ──────────────────────────
ENCRYPTION_KEY=change-me-to-a-base64-encoded-32-byte-key=

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=content_gen_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://postgres:change-me-strong-password@db:5432/content_gen_platform

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS / Hosts ───────────────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Storage ────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
# For MinIO:
# STORAGE_BACKEND=minio
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=content-gen
